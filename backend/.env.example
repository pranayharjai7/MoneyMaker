ENVIRONMENT=local
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-side-service-role-key
# Prefer Supabase JWKS for asymmetric JWT projects. Set SUPABASE_JWT_SECRET only for legacy symmetric projects.
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
JWT_AUDIENCE=authenticated

# Use localhost when running FastAPI/Celery directly from your host OS.
# Docker Compose overrides this to redis://redis:6379/0 for containers.
REDIS_URL=redis://localhost:6379/0

ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=

DEFAULT_TICKERS=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,JPM,UNH,V
ALERT_MIN_BUY_PROBABILITY=0.65
ALERT_MIN_EXPECTED_RETURN=0.03
ALERT_MAX_RISK_SCORE=0.55
NOTIFICATION_MAX_BUY_SIGNALS_PER_DAY=5
NOTIFICATION_MAX_SELL_ALERTS_PER_DAY=5
NOTIFICATION_COOLDOWN_HOURS_PER_STOCK=12
NOTIFICATION_DEFAULT_MIN_PROBABILITY=0.62
NOTIFICATION_HIGH_VOLATILITY_MIN_PROBABILITY=0.72
DRIFT_MIN_ACCURACY=0.52
DRIFT_MIN_SHARPE_RATIO=0.15
DRIFT_MAX_CALIBRATION_ERROR=0.18
DRIFT_PREDICTION_INSTABILITY_THRESHOLD=0.28
GUARDRAIL_MAX_POSITION_SIZE=0.12
GUARDRAIL_MAX_SECTOR_EXPOSURE=0.35
GUARDRAIL_MAX_DAILY_SIGNAL_VOLUME=25
GUARDRAIL_EXTREME_VOLATILITY_THRESHOLD=0.45
CORS_ORIGINS=*
