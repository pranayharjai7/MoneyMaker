NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Option A (easiest local dev): shared secret — must match backend DASHBOARD_API_KEY
NEXT_PUBLIC_DASHBOARD_API_KEY=change-me-local-dashboard-key

# Option B: static Supabase user access token (expires; use /login instead)
NEXT_PUBLIC_DASHBOARD_AUTH_TOKEN=

# Option C: Supabase login at /login
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
